# KAIROX Gestión — Variables de entorno
# Copia este archivo como .env.local y rellena con tus valores de Supabase

# URL del proyecto Supabase (Settings → API → Project URL)
VITE_SUPABASE_URL=https://XXXXXXXXXXXXXX.supabase.co

# Clave pública anon (Settings → API → Project API keys → anon public)
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.XXXXXX

# URL del proyecto Supabase de Ualá (Settings → API → Project URL)
VITE_UALA_SUPABASE_URL=https://your-uala-project.supabase.co

# Clave pública anon del proyecto Ualá (Settings → API → Project API keys → anon public)
VITE_UALA_SUPABASE_ANON_KEY=your-uala-supabase-anon-key
